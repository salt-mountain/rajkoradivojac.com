---
---

<section id="newsletter" class="py-24 px-4 sm:px-6 bg-dark-900">
  <div class="max-w-2xl mx-auto text-center">
    <h2 class="font-serif text-3xl sm:text-4xl font-bold text-white mb-4">
      Stay in Touch
    </h2>
    <p class="text-gray-400 mb-8 leading-relaxed">
      Join Rajko's mailing list for updates on new releases, events, and exclusive
      content. Be the first to know when a new book is on the way.
    </p>

    <!-- Newsletter form (placeholder - will be replaced with email provider embed) -->
    <form id="newsletter-form" class="flex flex-col sm:flex-row gap-4 max-w-lg mx-auto">
      <input
        type="email"
        name="email"
        required
        class="flex-1 px-4 py-3 bg-dark-700 border border-dark-500 rounded text-white placeholder-gray-500 focus:outline-none focus:border-primary transition-colors"
        placeholder="your@email.com"
      />
      <button
        type="submit"
        class="px-8 py-3 bg-primary text-dark-900 font-semibold uppercase tracking-wider text-sm rounded hover:bg-accent transition-colors duration-200 whitespace-nowrap"
      >
        Subscribe
      </button>
    </form>
    <p class="text-xs text-gray-500 mt-4">
      We respect your privacy. Unsubscribe anytime.
    </p>

    <!-- Contact info -->
    <div class="mt-16 pt-8 border-t border-dark-600">
      <h3 class="font-serif text-xl text-white mb-4">Contact</h3>
      <p class="text-gray-400 text-sm mb-4">
        For press inquiries, speaking engagements, or other questions:
      </p>
      <a
        href="mailto:contact@rajkoradivojac.com"
        class="text-primary hover:text-accent transition-colors"
      >
        contact@rajkoradivojac.com
      </a>
    </div>
  </div>
</section>
