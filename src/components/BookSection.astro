---
import type { Book } from '../data/books';

interface Props {
  book: Book;
  index: number;
}

const { book, index } = Astro.props;
const isEven = index % 2 === 0;
---

<section
  id={book.id}
  class:list={[
    'py-24 px-4 sm:px-6',
    index % 2 === 0 ? 'bg-dark-900' : 'bg-dark-800',
  ]}
>
  <div
    class:list={[
      'max-w-6xl mx-auto flex flex-col gap-12 items-center',
      isEven ? 'md:flex-row' : 'md:flex-row-reverse',
    ]}
  >
    <!-- Book cover -->
    <div class="flex-shrink-0 w-64 sm:w-72 md:w-80">
      <div class="relative group" style="perspective: 1000px;">
        <div
          class="book-cover-placeholder w-full aspect-[2/3] rounded-lg shadow-2xl transition-transform duration-500 group-hover:scale-105"
          style={`transform: rotateY(${isEven ? '-5' : '5'}deg);`}
        >
          <div class="flex flex-col items-center justify-center h-full">
            <span class="text-primary font-serif text-2xl font-bold mb-2">{book.title}</span>
            {book.subtitle && (
              <span class="text-gray-400 text-sm italic">{book.subtitle}</span>
            )}
            <span class="text-gray-500 text-xs mt-4">[ Cover Image ]</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Book info -->
    <div class="flex-1 max-w-xl">
      <h2 class="font-serif text-3xl sm:text-4xl font-bold text-white mb-2">
        {book.title}
      </h2>
      {book.subtitle && (
        <p class="text-primary font-serif italic text-lg mb-4">{book.subtitle}</p>
      )}
      <div class="flex items-center gap-4 text-sm text-gray-500 mb-6">
        <span>{book.format}</span>
        <span>&middot;</span>
        <span>{book.price}</span>
        <span>&middot;</span>
        <span>{book.publishYear}</span>
      </div>
      <p class="text-gray-300 leading-relaxed mb-8">
        {book.description}
      </p>

      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href={book.amazonUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center px-6 py-3 bg-primary text-dark-900 font-semibold uppercase tracking-wider text-sm rounded hover:bg-accent transition-colors duration-200"
        >
          <svg class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="currentColor">
            <path d="M.045 18.02c.072-.116.187-.124.348-.022 3.636 2.11 7.594 3.166 11.87 3.166 2.852 0 5.668-.533 8.447-1.595l.315-.14c.138-.06.234-.1.293-.13.226-.088.39-.046.493.126.12.19.065.377-.169.56-.988.775-2.268 1.47-3.835 2.088-1.568.618-3.14 1.04-4.72 1.27-.654.094-1.29.14-1.91.14-2.19 0-4.36-.396-6.51-1.186C2.477 21.456.87 20.333.045 18.97v-.95zm6.094-5.46c0-.95.242-1.76.725-2.435.483-.674 1.123-1.18 1.918-1.513.86-.36 1.826-.595 2.898-.706.368-.04.93-.09 1.69-.15v-.612c0-.748-.085-1.275-.254-1.578-.33-.522-.863-.783-1.596-.783h-.17c-.447.03-.836.164-1.166.395-.33.23-.55.538-.666.914-.076.255-.192.397-.35.425l-2.028-.272c-.178-.04-.267-.136-.267-.29 0-.04.007-.09.022-.15.285-1.474 1.07-2.547 2.36-3.218.576-.29 1.23-.488 1.964-.59.373-.055.746-.082 1.12-.082 1.606 0 2.822.474 3.65 1.424.332.38.574.814.728 1.303.153.49.23 1.086.23 1.793v3.327c0 .946.21 1.725.63 2.337.178.264.383.503.614.716.095.09.146.17.155.245 0 .096-.056.178-.17.248-.652.564-1.423 1.242-2.314 2.03-.163.12-.354.127-.572.022-.36-.34-.617-.61-.774-.812l-.252-.337c-.75.787-1.525 1.283-2.327 1.488-.482.122-.982.182-1.498.182-1.08 0-1.966-.343-2.663-1.03-.697-.688-1.046-1.586-1.046-2.697zm3.4-.282c0 .553.162 1.028.487 1.424.325.397.738.595 1.238.595.076 0 .17-.013.28-.04.112-.027.192-.05.242-.073.698-.33 1.218-.91 1.558-1.74.14-.34.233-.703.28-1.09.045-.387.068-.854.068-1.4v-.813c-.553 0-1.013.023-1.382.068-1.16.14-1.945.572-2.36 1.3-.205.36-.308.788-.308 1.285v.484z" />
          </svg>
          Buy on Amazon
        </a>

        {book.hasExcerpt && (
          <button
            class="excerpt-btn inline-flex items-center justify-center px-6 py-3 border border-primary text-primary font-semibold uppercase tracking-wider text-sm rounded hover:bg-primary hover:text-dark-900 transition-colors duration-200"
            data-book-id={book.id}
            data-book-title={book.title}
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
            Free Excerpt
          </button>
        )}
      </div>
    </div>
  </div>
</section>
