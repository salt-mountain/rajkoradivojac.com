---
---

<!-- Excerpt signup modal -->
<div
  id="excerpt-modal"
  class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/80 backdrop-blur-sm"
>
  <div class="relative bg-honey-50 rounded-lg shadow-2xl max-w-md w-full mx-4 p-8">
    <!-- Close button -->
    <button
      id="modal-close"
      class="absolute top-4 right-4 text-honey-700 hover:text-dark-900 transition-colors"
      aria-label="Close"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <div class="text-center mb-6">
      <svg class="w-12 h-12 text-honey-700 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
      </svg>
      <h3 class="font-serif text-2xl font-bold text-dark-900 mb-2">
        Read a Free Excerpt
      </h3>
      <p id="modal-book-title" class="text-honey-800 italic mb-2"></p>
      <p class="text-dark-800 text-sm">
        Sign up for Rajko's newsletter to receive your free excerpt. You'll also get updates on new releases and events.
      </p>
    </div>

    <!-- Signup form (placeholder - will be replaced with email provider embed) -->
    <form id="excerpt-form" class="space-y-4">
      <div>
        <label for="excerpt-name" class="block text-sm text-dark-800 mb-1">Name</label>
        <input
          type="text"
          id="excerpt-name"
          name="name"
          required
          class="w-full px-4 py-2 bg-white border border-honey-300 rounded text-dark-900 placeholder-honey-600 focus:outline-none focus:border-honey-700 transition-colors"
          placeholder="Your name"
        />
      </div>
      <div>
        <label for="excerpt-email" class="block text-sm text-dark-800 mb-1">Email</label>
        <input
          type="email"
          id="excerpt-email"
          name="email"
          required
          class="w-full px-4 py-2 bg-white border border-honey-300 rounded text-dark-900 placeholder-honey-600 focus:outline-none focus:border-honey-700 transition-colors"
          placeholder="your@email.com"
        />
      </div>
      <button
        type="submit"
        class="w-full px-6 py-3 bg-honey-700 text-honey-50 font-semibold uppercase tracking-wider text-sm rounded hover:bg-honey-800 transition-colors duration-200"
      >
        Send Me the Excerpt
      </button>
      <p class="text-xs text-honey-700 text-center">
        We respect your privacy. Unsubscribe anytime.
      </p>
    </form>

    <!-- Success state -->
    <div id="excerpt-success" class="hidden text-center">
      <svg class="w-16 h-16 text-green-500 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <h4 class="font-serif text-xl font-bold text-dark-900 mb-2">Check Your Email!</h4>
      <p class="text-dark-800 text-sm">
        Your free excerpt is on its way. Check your inbox (and spam folder, just in case).
      </p>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById('excerpt-modal');
  const closeBtn = document.getElementById('modal-close');
  const form = document.getElementById('excerpt-form');
  const success = document.getElementById('excerpt-success');
  const bookTitle = document.getElementById('modal-book-title');

  // Open modal from excerpt buttons
  document.querySelectorAll('.excerpt-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const title = (btn as HTMLElement).dataset.bookTitle;
      if (bookTitle) bookTitle.textContent = title || '';
      form?.classList.remove('hidden');
      success?.classList.add('hidden');
      modal?.classList.remove('hidden');
      modal?.classList.add('flex');
    });
  });

  // Close modal
  function closeModal() {
    modal?.classList.add('hidden');
    modal?.classList.remove('flex');
  }

  closeBtn?.addEventListener('click', closeModal);
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });

  // Form submit placeholder
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    // TODO: Replace with actual email provider integration (ConvertKit, Mailchimp, etc.)
    form.classList.add('hidden');
    success?.classList.remove('hidden');
  });
</script>
