---

---

<!-- Excerpt signup modal -->
<div
  id="excerpt-modal"
  class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/80 backdrop-blur-sm"
>
  <div
    class="relative bg-navy-800 rounded-lg shadow-2xl max-w-md w-full mx-4 p-8"
  >
    <!-- Close button -->
    <button
      id="modal-close"
      class="absolute top-4 right-4 text-gray-400 hover:text-white transition-colors"
      aria-label="Close"
    >
      <svg
        class="w-6 h-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>

    <div class="text-center mb-6">
      <svg
        class="w-12 h-12 text-primary mx-auto mb-4"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="1.5"
          d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
        ></path>
      </svg>
      <h3 class="font-serif text-2xl font-bold text-white mb-2">
        Read a Free Excerpt
      </h3>
      <p id="modal-book-title" class="text-primary italic mb-2"></p>
      <p class="text-gray-400 text-sm">
        Enter your details and we'll email you a confirmation link. Click it and
        your free excerpt is on its way — plus occasional updates on new
        releases.
      </p>
    </div>

    <form id="excerpt-form" class="space-y-4" novalidate>
      <div>
        <label for="excerpt-name" class="block text-sm text-gray-400 mb-1"
          >Name</label
        >
        <input
          type="text"
          id="excerpt-name"
          name="name"
          required
          class="w-full px-4 py-2 bg-navy-700 border border-navy-600 rounded text-white placeholder-gray-500 focus:outline-none focus:border-primary transition-colors"
          placeholder="Your name"
        />
      </div>
      <div>
        <label for="excerpt-email" class="block text-sm text-gray-400 mb-1"
          >Email</label
        >
        <input
          type="email"
          id="excerpt-email"
          name="email"
          required
          class="w-full px-4 py-2 bg-navy-700 border border-navy-600 rounded text-white placeholder-gray-500 focus:outline-none focus:border-primary transition-colors"
          placeholder="your@email.com"
        />
      </div>

      <!-- Honeypot: hidden from humans, bots tend to fill it. -->
      <input
        type="text"
        name="website"
        tabindex="-1"
        autocomplete="off"
        aria-hidden="true"
        style="position:absolute;left:-9999px"
      />

      <p id="excerpt-error" class="hidden text-sm text-red-400 text-center"></p>

      <button
        id="excerpt-submit"
        type="submit"
        class="w-full px-6 py-3 bg-primary text-navy-950 font-semibold uppercase tracking-wider text-sm rounded hover:bg-accent transition-colors duration-200 disabled:opacity-60 disabled:cursor-not-allowed"
      >
        Send Me the Excerpt
      </button>
      <p class="text-xs text-gray-500 text-center">
        We respect your privacy. Unsubscribe anytime.
      </p>
    </form>

    <!-- Success state -->
    <div id="excerpt-success" class="hidden text-center">
      <svg
        class="w-16 h-16 text-green-500 mx-auto mb-4"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
      <h4 class="font-serif text-xl font-bold text-white mb-2">
        Check your inbox!
      </h4>
      <p class="text-gray-400 text-sm">
        We've sent you a confirmation link. Click it to confirm your email and
        receive your excerpt. (Check spam, just in case.)
      </p>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById("excerpt-modal");
  const closeBtn = document.getElementById("modal-close");
  const form = document.getElementById(
    "excerpt-form",
  ) as HTMLFormElement | null;
  const success = document.getElementById("excerpt-success");
  const bookTitleEl = document.getElementById("modal-book-title");
  const errorEl = document.getElementById("excerpt-error");
  const submitBtn = document.getElementById(
    "excerpt-submit",
  ) as HTMLButtonElement | null;

  let currentBookSlug: string | null = null;

  function openModal(slug: string | null, title: string | null) {
    currentBookSlug = slug;
    if (bookTitleEl) bookTitleEl.textContent = title || "";
    form?.reset();
    form?.classList.remove("hidden");
    success?.classList.add("hidden");
    errorEl?.classList.add("hidden");
    modal?.classList.remove("hidden");
    modal?.classList.add("flex");
  }

  function closeModal() {
    modal?.classList.add("hidden");
    modal?.classList.remove("flex");
  }

  document.querySelectorAll(".excerpt-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const el = btn as HTMLElement;
      openModal(
        el.dataset.excerptBook ?? null,
        el.dataset.excerptTitle ?? null,
      );
    });
  });

  closeBtn?.addEventListener("click", closeModal);
  modal?.addEventListener("click", (e) => {
    if (e.target === modal) closeModal();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeModal();
  });

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!form) return;

    const data = new FormData(form);
    const email = String(data.get("email") ?? "").trim();
    const name = String(data.get("name") ?? "").trim();
    const website = String(data.get("website") ?? "");

    if (!email) {
      errorEl?.classList.remove("hidden");
      if (errorEl) errorEl.textContent = "Please enter your email.";
      return;
    }

    errorEl?.classList.add("hidden");
    if (submitBtn) submitBtn.disabled = true;

    try {
      const res = await fetch("/api/subscribe", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          email,
          name,
          book_slug: currentBookSlug,
          website,
        }),
      });

      // Only a server error (5xx) is surfaced; everything else shows the same
      // generic success so subscriber state can't be probed.
      if (res.status >= 500) throw new Error("server");

      form.classList.add("hidden");
      success?.classList.remove("hidden");
    } catch {
      errorEl?.classList.remove("hidden");
      if (errorEl)
        errorEl.textContent =
          "Something went wrong. Please try again in a moment.";
    } finally {
      if (submitBtn) submitBtn.disabled = false;
    }
  });
</script>
