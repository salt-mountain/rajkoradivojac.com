---
---

<section
  id="hero"
  class="relative min-h-screen flex items-center justify-center bg-honey-200 pt-16"
>
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-5">
    <div
      class="absolute inset-0"
      style="background-image: radial-gradient(circle at 1px 1px, rgba(139,105,20,0.15) 1px, transparent 0); background-size: 40px 40px;"
    >
    </div>
  </div>

  <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
    <h1 class="font-serif text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-bold text-dark-900 mb-6 tracking-tight">
      Rajko Radivojac
    </h1>
    <p class="text-xl sm:text-2xl text-honey-800 font-serif italic mb-8">
      Author of practical beekeeping books and children's picture books
    </p>
    <p class="text-lg text-dark-800 max-w-2xl mx-auto mb-12 leading-relaxed">
      I write practical books on beekeeping under my own name and publish selected
      children's picture books under the pen name <strong class="text-dark-900">Ray Smart</strong>. This site brings together my
      books, background, and current work.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="#book-1"
        class="inline-block px-8 py-3 bg-honey-700 text-honey-50 font-semibold uppercase tracking-wider text-sm rounded hover:bg-honey-800 transition-colors duration-200"
      >
        Explore Books
      </a>
      <a
        href="#newsletter"
        class="inline-block px-8 py-3 border border-honey-700 text-honey-800 font-semibold uppercase tracking-wider text-sm rounded hover:bg-honey-700 hover:text-honey-50 transition-colors duration-200"
      >
        Stay in Touch
      </a>
    </div>

  </div>
</section>
