---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Link expired — Rajko Radivojac">
  <main class="min-h-screen flex items-center justify-center px-4 bg-navy-950">
    <div class="max-w-md w-full text-center bg-navy-800 rounded-lg shadow-2xl p-10">
      <svg class="w-16 h-16 text-amber-400 mx-auto mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <h1 class="font-serif text-3xl font-bold text-white mb-3">This link didn't work</h1>
      <p class="text-gray-400 leading-relaxed mb-8">
        Your confirmation link is invalid or has expired (links are valid for 7 days).
        Head back and request your excerpt again, and we'll send a fresh link.
      </p>
      <a
        href="/"
        class="inline-flex items-center justify-center px-6 py-3 bg-primary text-navy-950 font-semibold uppercase tracking-wider text-sm rounded hover:bg-accent transition-colors duration-200"
      >
        Back to the site
      </a>
    </div>
  </main>
</Layout>
