---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Welcome back — Rajko Radivojac">
  <main class="min-h-screen flex items-center justify-center px-4 bg-navy-950">
    <div
      class="max-w-md w-full text-center bg-navy-800 rounded-lg shadow-2xl p-10"
    >
      <svg
        class="w-16 h-16 text-green-500 mx-auto mb-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
      <h1 class="font-serif text-3xl font-bold text-white mb-3">
        Welcome back!
      </h1>
      <p id="welcome-message" class="text-gray-400 leading-relaxed mb-8">
        You're resubscribed. If you requested an excerpt, it's on its way to
        your inbox.
      </p>
      <a
        href="/"
        class="inline-flex items-center justify-center px-6 py-3 bg-primary text-navy-950 font-semibold uppercase tracking-wider text-sm rounded hover:bg-accent transition-colors duration-200"
      >
        Back to the site
      </a>
    </div>
  </main>
</Layout>

<script>
  const book = new URLSearchParams(window.location.search).get("book");
  const el = document.getElementById("welcome-message");
  if (book && el) {
    el.textContent =
      "You're resubscribed — your free excerpt is on its way to your inbox.";
  }
</script>
